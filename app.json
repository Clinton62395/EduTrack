{
  "expo": {
    "name": "EduTrack",
    "slug": "edutrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "edutrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.billydoumbouya.EduTrack",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Autoriser EduTrack à utiliser le microphone pour enregistrer vos messages vocaux.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.billydoumbouya.EduTrack",
      "adaptiveIcon": {
        "backgroundColor": "#0A0F2E",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Autoriser EduTrack à utiliser le microphone pour enregistrer vos messages vocaux."
        }
      ],
      [
        "expo-audio",
        {
          "allowsBackgroundAudio": true,
          "staysActiveInBackground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0F2E",
          "dark": {
            "backgroundColor": "#0A0F2E"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser EduTrack à accéder à vos photos pour votre profil et vos cours.",
          "cameraPermission": "Autoriser EduTrack à utiliser la caméra.",
          "allowBase64": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-logo.png",
          "color": "#2563EB"
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-firebase/app",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "edutrack",
          "organization": "g-tech-academy"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "180b4312-679e-4164-a5a0-2bfe1b1932a2"
      }
    },
    "owner": "g-tech-academy",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/180b4312-679e-4164-a5a0-2bfe1b1932a2",
      "enabled": true,
      "fallbackToCacheTimeout": 30000
    }
  }
}
