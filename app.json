{
  "expo": {
    "name": "EduTrack",
    "slug": "EduTrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "edutrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.billydoumbouya.EduTrack",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Autoriser EduTrack à utiliser le microphone pour enregistrer vos messages vocaux.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.billydoumbouya.EduTrack",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "usesCleartextTraffic": false
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Autoriser EduTrack à utiliser le microphone pour enregistrer vos messages vocaux."
        }
      ],
      [
        "expo-audio",
        {
          "allowsBackgroundAudio": true,
          "staysActiveInBackground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser EduTrack à accéder à vos photos pour votre profil et vos cours.",
          "cameraPermission": "Autoriser EduTrack à utiliser la caméra.",
          "allowBase64": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-logo.png",
          "color": "#2563EB"
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-firebase/app",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "edutrack",
          "organization": "g-tech-academy"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03922016-5439-4bb9-9fae-f5a8018b0b25"
      }
    },
    "owner": "billydoumbouya",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/03922016-5439-4bb9-9fae-f5a8018b0b25"
    }
  }
}
